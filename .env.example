# ============================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO
# ============================================
# Copiar este archivo a .env.local para desarrollo local
# y configurar las mismas variables en Vercel / hosting de producción.

# --- Admin ---
# Contraseña para acceder al panel /admin
# IMPORTANTE: cambiar antes de deployar a producción
ADMIN_PASSWORD=admin123

# --- Email de leads (Resend) ---
# 1) Crear cuenta gratis en https://resend.com (3.000 emails/mes gratis)
# 2) Generar API key en https://resend.com/api-keys
# 3) Pegar la key acá:
RESEND_API_KEY=

# Dirección "from" del email al broker.
# Default: onboarding@resend.dev (funciona sin configurar dominio,
#   pero solo envía al email registrado en Resend — sirve para testing).
# Para producción: verificar dominio propio en https://resend.com/domains
#   y usar algo como leads@tudominio.com
LEAD_FROM_EMAIL=onboarding@resend.dev
